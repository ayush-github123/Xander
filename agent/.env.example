# GROQ Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
AGENT_ENABLE_LLM=true
GROQ_CACHE_ENABLED=true
GROQ_TIMEOUT_SECONDS=30

# Paths & Directories
AGENT_CONTEXT_DIRECTORY=/home/ayushrai/Documents/xander/context-engine/context-output
AGENT_LOG_DIR=/home/ayushrai/Documents/xander/agent/logs

# Execution Mode
AGENT_EXECUTION_MODE=cli
# Options: cli (single analysis), daemon (continuous monitoring), watch (event-driven, future)

# Analysis Thresholds
AGENT_CONFIDENCE_THRESHOLD=0.5
AGENT_ANOMALY_DEDUP_WINDOW=300
AGENT_SIGNAL_QUALITY_WEIGHT=0.6
AGENT_CRITICAL_CPU_THRESHOLD=90.0
AGENT_CRITICAL_MEMORY_THRESHOLD=85.0
AGENT_CRITICAL_ANOMALY_THRESHOLD=5
AGENT_EXTREME_CASE_THRESHOLD=0.85

# Polling (for daemon mode)
AGENT_POLL_INTERVAL_SECONDS=60

# Output
AGENT_OUTPUT_FORMAT=markdown
# AGENT_OUTPUT_FILE=/var/log/xander-analysis.md  # Optional: write to file instead of stdout

# Logging
AGENT_LOG_LEVEL=INFO
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
AGENT_AUDIT_LOG_ENABLED=true
